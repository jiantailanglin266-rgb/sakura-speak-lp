# Sakura Speak — backend env
# Copy to .env.local and fill in to switch from the localStorage mock to real
# Supabase auth + database. Both values are safe to expose in the browser
# (the anon key is public; Row Level Security in supabase/schema.sql protects data).
#
# Leave these EMPTY to keep running on the built-in localStorage mock
# (used by the current static GitHub Pages preview and credential-free local dev).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site URL — drives canonical links, OpenGraph, sitemap.xml and robots.txt.
# Leave empty to use the placeholder; set your real domain at launch.
NEXT_PUBLIC_SITE_URL=

# Stripe — optional. Create one Payment Link per plan in your Stripe dashboard
# and paste the URLs here to switch the subscribe screen from the mock checkout
# to real Stripe-hosted payment (no server required). Leave empty to keep the mock.
NEXT_PUBLIC_STRIPE_LINK_MONTHLY=
NEXT_PUBLIC_STRIPE_LINK_3MONTH=
NEXT_PUBLIC_STRIPE_LINK_YEARLY=
NEXT_PUBLIC_STRIPE_LINK_LIFETIME=

# YouTube Data API — optional. Powers Anime Learning with live official anime
# videos. Without it, the screen uses bundled mock videos and never breaks.
NEXT_PUBLIC_YOUTUBE_API_KEY=

# News RSS — optional. Point News at one or more RSS/Atom feeds and it updates
# itself automatically (fetched in the browser, cached ~30 min, with a Refresh
# button). Leave empty to keep the curated mock articles.
# Comma-separated. Each entry is "URL" or "Label|URL" to set the source label:
#   NEXT_PUBLIC_NEWS_RSS_FEEDS=Easy Japanese|https://www3.nhk.or.jp/news/easy/news-list.xml,NHK|https://www3.nhk.or.jp/rss/news/cat0.xml
NEXT_PUBLIC_NEWS_RSS_FEEDS=
# CORS proxy used to fetch feeds (most feeds lack CORS headers). The feed URL is
# appended, URL-encoded. Unset/empty = the keyless allorigins default. Set your
# own proxy/serverless function for production, or set it to "none" to fetch the
# feeds directly (only works for feeds that already send CORS headers).
NEXT_PUBLIC_RSS_PROXY=
